---
import { personalInformation, cvFiles, profileImage } from "../profile";
import Icon from "./Icon.astro";
---

<section class="hero reveal">
  <div class="hero-content">
    <div class="hero-image-wrapper">
      {
        profileImage && (
          <img src={profileImage} alt="Ramiro Depaoli" class="hero-image" />
        )
      }
    </div>
    <h1 class="hero-name">Ramiro Depaoli</h1>
    <p class="hero-title">{personalInformation.title}</p>
    <p class="hero-location">{personalInformation.location}</p>
    <div class="hero-contact">
      <a href={`mailto:${personalInformation.email}`} class="btn btn-outline">
        <Icon name="mail" /> Email
      </a>
      <a
        href={personalInformation.github}
        target="_blank"
        class="btn btn-outline"
      >
        <Icon name="github" /> GitHub
      </a>
      <a
        href={personalInformation.linkedin}
        target="_blank"
        class="btn btn-outline"
      >
        <Icon name="linkedin" /> LinkedIn
      </a>
    </div>
    <div class="hero-cv">
      <a href={cvFiles.en} download class="btn btn-primary">
        <Icon name="download" /> Download CV (EN)
      </a>
      <a href={cvFiles.es} download class="btn btn-primary">
        <Icon name="download" /> Download CV (ES)
      </a>
      <a href={cvFiles.utn} download class="btn btn-primary">
        <Icon name="download" /> Download UTN CERT (ES)
      </a>
    </div>
  </div>
  <div class="hero-background">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    position: relative;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .hero-image-wrapper {
    margin-bottom: 2rem;
  }

  .hero-image {
    width: 300px;
    height: 300px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--accent-primary);
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.3);
  }

  .hero-name {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #fff, #a0a0a0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-title {
    font-size: 1.5rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .hero-location {
    font-size: 1.2rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .hero-contact {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hero-cv {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: float 20s infinite;
  }

  .shape-1 {
    width: 400px;
    height: 400px;
    background: var(--accent-primary);
    top: -100px;
    right: -100px;
  }

  .shape-2 {
    width: 300px;
    height: 300px;
    background: var(--accent-secondary);
    bottom: -50px;
    left: -50px;
    animation-delay: -5s;
  }

  .shape-3 {
    width: 200px;
    height: 200px;
    background: #f59e0b;
    top: 50%;
    left: 30%;
    animation-delay: -10s;
  }

  @keyframes float {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(50px, -30px) scale(1.1);
    }
    50% {
      transform: translate(20px, 50px) scale(0.9);
    }
    75% {
      transform: translate(-30px, -20px) scale(1.05);
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
    }
    .hero-contact,
    .hero-cv {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
