---
import { education } from "../profile";
import Icon from "./Icon.astro";
---

<section class="education reveal">
  <h2>Education</h2>
  <div class="education-list">
    {
      education.map((edu) => (
        <div class="edu-item card">
          <div class="edu-year">
            <Icon name="calendar" /> {edu.year}
          </div>
          <div class="edu-details">
            <h3>{edu.degree}</h3>
            <p>{edu.institution}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .education-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .edu-item {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem;
  }
  .edu-year {
    min-width: 120px;
    color: var(--accent-primary);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .edu-details h3 {
    font-size: 1.2rem;
    margin-bottom: 0.25rem;
  }
  .edu-details p {
    color: var(--text-secondary);
  }
  @media (max-width: 640px) {
    .edu-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
