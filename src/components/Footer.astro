---
import { personalInformation } from "../profile";
import Icon from "./Icon.astro";
---

<footer class="footer reveal">
  <div class="footer-links">
    <a href={`mailto:${personalInformation.email}`}><Icon name="mail" /></a>
    <a href={personalInformation.github} target="_blank"
      ><Icon name="github" /></a
    >
    <a href={personalInformation.linkedin} target="_blank"
      ><Icon name="linkedin" /></a
    >
  </div>
  <div class="footer-copyright">
    © {new Date().getFullYear()} {personalInformation.name}. All rights reserved.
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a {
    color: var(--text-secondary);
    transition: color 0.3s ease;
  }
  .footer-links a:hover {
    color: var(--accent-primary);
  }
  .footer-copyright {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
</style>
