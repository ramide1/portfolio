---
import { personalInfo } from '../data/profile';
---

<section class="about reveal" id="about">
  <h2>About Me</h2>
  <div class="about-content">
    <p class="about-text">{personalInfo.about}</p>
  </div>
</section>

<style>
  .about {
    max-width: 800px;
  }
  .about-text {
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }
</style>